# ============================================
# RATAPLAM - Configurações do Backend (API)
# Copie para .env e preencha os valores
# ============================================

# ── Banco de Dados ─────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rataplam
DB_USER=rataplam_user
DB_PASS=sua_senha_forte_aqui

# ── URLs ───────────────────────────────────
# URL base da API (sem barra final)
API_BASE_URL=https://seudominio.com.br/api
# URL do frontend (para links em e-mails)
FRONTEND_URL=https://seudominio.com.br

# ── Cron Jobs ─────────────────────────────
# Chave secreta para autenticar o cron externo
# Gere com: php -r "echo bin2hex(random_bytes(32));"
CRON_SECRET_KEY=troque_para_uma_chave_longa_e_aleatoria

# ── MercadoPago ───────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxx
MERCADOPAGO_WEBHOOK_SECRET=xxxx

# ── Stripe ────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── SMTP ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=seu_email@gmail.com
SMTP_PASS=senha_de_app_gmail
SMTP_FROM_NAME=RATAPLAM
SMTP_FROM_EMAIL=contato@rataplam.com.br

# ── Replicate (Provador Virtual com IA) ───
REPLICATE_API_TOKEN=r8_xxxx
