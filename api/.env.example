# ============================================
# RATAPLAM - Configuracao do Banco de Dados
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rataplam
DB_USER=root
DB_SECRET=

# ============================================
# Frontend URL (para links de email)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Chave secreta para cron jobs
# ============================================
CRON_SECRET_KEY=rataplam_cron_$(php -r "echo md5('rataplam');")

# ============================================
# API Replicate (Provador Virtual)
# ============================================
REPLICATE_API_TOKEN=
